# E621 API Configuration
# This is required. You can find your API key here: https://e621.net/api_keys
# The user account must have Moderator permissions or greater. Otherwise, moderation data sync will fail.
E621_GLOBAL_USERNAME=your_username_here
E621_GLOBAL_API_KEY=your_api_key_here

# PostgreSQL Database Configuration
# In dev, these point at the Postgres container published by compose.override.yml.
# In the full Docker setup, compose.yml sets these and this section is ignored.
DB_HOST=localhost
DB_PORT=34572
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=six_oclock

# Redis Configuration
# In dev, points at the Redis container published by compose.override.yml.
REDIS_HOST=localhost
REDIS_PORT=34573

# Server Port
# PORT=34571

# Localhost is always allowed. Add your hosting domain here in production.
# CORS_ALLOWED_ORIGINS=

# Stores files like the server JWT key. Must be persistent.
# DATA_DIR=./data

# Server Administration. 
# Comma-separated list of users that can administer the server.
# If left empty, the GLOBAL user will be the only admin.
# SERVER_ADMINS=

# Development Settings
# Comment out or remove in production.
NODE_ENV=development