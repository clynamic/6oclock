{
  "name": "@6oclock/api",
  "version": "1.0.0",
  "private": true,
  "description": "backend data aggregate for 6 o'clock",
  "license": "MIT",
  "author": "binaryfloof",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node main.js",
    "lint": "eslint src --fix",
    "format": "prettier --write src",
    "test": "jest",
    "typeorm": "typeorm-ts-node-commonjs",
    "migrate": "typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "generate": "orval",
    "db:reset": "npm run typeorm schema:drop -- -d src/data-source.ts && npm run typeorm schema:sync -- -d src/data-source.ts"
  },
  "dependencies": {
    "@date-fns/tz": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/typeorm": "^11.0.1",
    "axios": "^1.7.5",
    "bullmq": "^5.73.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cron": "4.4.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "joi": "^18.2.1",
    "keyv": "^5.6.0",
    "lodash": "^4.17.21",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.7",
    "@types/node": "^25.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "es-aggregate-error": "^1.0.13",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.0.0",
    "express": "^5.2.1",
    "globals": "^17.6.0",
    "jest": "^30.1.3",
    "openapi-types": "^12.1.3",
    "orval": "7.11.2",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.45.0",
    "webpack": "^5.94.0"
  },
  "engines": {
    "node": ">=20",
    "npm": "please-use-yarn"
  }
